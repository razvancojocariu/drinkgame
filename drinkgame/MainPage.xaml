<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="drinkgame.Views.MainPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <Grid IgnoreSafeArea="True">
        <!-- Background image - using opacity directly to avoid Android overlay bugs -->
        <Image Source="bereaa"
               Aspect="AspectFill"
               Opacity="0.6" />

        <!-- Content -->
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="24"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Fill"
                                 Padding="32,40">
                <Label x:Name="LogoLabel"
                       Text="Esti pregatit?"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="White"
                       FontFamily="Bangers"
                       HorizontalOptions="Center"
                       Opacity="1">
                    <Label.Shadow>
                        <Shadow Brush="Black" Radius="5" Offset="2,2"/>
                    </Label.Shadow>
                </Label>

                <Label Text="Regulile sunt simple:
bei, râzi… și regreți mâine."
                       FontSize="18"
                       TextColor="White"
                       HorizontalOptions="Center"/>

                <Button Text="Vreau să risc"
                        Clicked="OnStartClicked"
                        WidthRequest="220"
                        HeightRequest="60"
                        BackgroundColor="#2ECC71"
                        TextColor="White"
                        CornerRadius="30"
                        FontAttributes="Bold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        Margin="0,16,0,0">
                    <Button.Shadow>
                        <Shadow Brush="Black" Radius="5" Offset="2,2"/>
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>

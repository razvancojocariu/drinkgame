<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="drinkgame.Views.StatisticsPage"
             BackgroundColor="#1a1a2e"
             Title="Statistics">

    <Grid RowDefinitions="Auto,Auto,*,Auto" 
          Padding="0"
          ColumnDefinitions="*"
          RowSpacing="0"
          ColumnSpacing="0">

        <!-- Row 0: Top bar with back arrow -->
        <Grid Grid.Row="0" 
              ColumnDefinitions="Auto,*" 
              Padding="10" 
              BackgroundColor="#0f0f1a">
            <Button Grid.Column="0"
                    Text="←"
                    Command="{Binding BackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="28"
                    CornerRadius="8"
                    WidthRequest="50"
                    HeightRequest="50"
                    Padding="5"/>
        </Grid>

        <!-- Row 1: Title -->
        <Label Grid.Row="1"
               Grid.Column="0"
               Text="Rezultatele Serii 🏆"
               TextColor="Gold" 
               FontSize="28"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" 
               Margin="0,10,0,20"
               Padding="20,0"/>

        <!-- Row 2: Players List -->
        <CollectionView Grid.Row="2"
                       Grid.Column="0"
                       ItemsSource="{Binding RankedPlayers}"
                       SelectionMode="None"
                       VerticalScrollBarVisibility="Always"
                       Margin="20,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#16213e" 
                           BorderColor="#e94560"
                           CornerRadius="15" 
                           Padding="15" 
                           Margin="0,5"
                           HasShadow="True">
                        <VerticalStackLayout Spacing="5">
                            <!-- Player Name and Badge -->
                            <StackLayout Orientation="Horizontal" Spacing="10">
                                <Label Text="{Binding Rank, StringFormat='{0}. '}"
                                       TextColor="Gold"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       WidthRequest="40"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding Name}"
                                       TextColor="White"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       HorizontalOptions="FillAndExpand"/>
                                <Label Text="{Binding Badge}"
                                       TextColor="{Binding BadgeColor}"
                                       FontSize="12"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding HasBadge}"/>
                            </StackLayout>

                            <!-- Stats -->
                            <StackLayout Orientation="Horizontal" Spacing="20">
                                <StackLayout HorizontalOptions="FillAndExpand">
                                    <Label Text="Provocări Completate"
                                           TextColor="#a0a0a0"
                                           FontSize="12"/>
                                    <Label Text="{Binding ChallengesCompleted, StringFormat='{0}'}"
                                           TextColor="#90EE90"
                                           FontSize="16"
                                           FontAttributes="Bold"/>
                                </StackLayout>

                                <StackLayout HorizontalOptions="FillAndExpand">
                                    <Label Text="Provocări Skipped"
                                           TextColor="#a0a0a0"
                                           FontSize="12"/>
                                    <Label Text="{Binding ChallengesSkipped, StringFormat='{0}'}"
                                           TextColor="#FF6B6B"
                                           FontSize="16"
                                           FontAttributes="Bold"/>
                                </StackLayout>
                            </StackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Row 3: Back to Menu Button -->
        <Button Grid.Row="3"
                Grid.Column="0"
                Text="Joc Nou"
                Command="{Binding PlayAgainCommand}"
                BackgroundColor="#e94560" 
                TextColor="White"
                FontSize="18" 
                CornerRadius="12"
                Padding="15,10"
                Margin="20,20,20,10"
                HorizontalOptions="Fill"/>

    </Grid>
</ContentPage>

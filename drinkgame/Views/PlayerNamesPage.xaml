<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="drinkgame.Views.PlayerNamesPage"
             x:Name="PlayerNamesPageRoot"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">

    <AbsoluteLayout>

        <!-- Background image — Source set at runtime, same fix as MainPage -->
        <Image x:Name="BgImage"
               Aspect="AspectFill"
               Opacity="0.7"
               AbsoluteLayout.LayoutFlags="All"
               AbsoluteLayout.LayoutBounds="0,0,1,1" />

        <!-- Dark overlay -->
        <BoxView Color="Black"
                 Opacity="0.7"
                 AbsoluteLayout.LayoutFlags="All"
                 AbsoluteLayout.LayoutBounds="0,0,1,1" />

        <!-- Content: fixed header + scrollable player list + footer buttons -->
        <Grid Padding="20,16"
              RowDefinitions="Auto,*,Auto"
              AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1">

            <!-- Header -->
            <Label Grid.Row="0"
                   Text="Lista victimelor de diseară"
                   FontSize="28"
                   TextColor="#FFFFFF"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16">
                <Label.Shadow>
                    <Shadow Brush="Black" Radius="6" Offset="2,2"/>
                </Label.Shadow>
            </Label>

            <!-- Player Names — CollectionView scrolls in the Star row -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding PlayerNames}"
                            SelectionMode="None"
                            Margin="0,0,0,12">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#22FFFFFF"
                               BorderColor="#44FFFFFF"
                               CornerRadius="18"
                               Padding="12"
                               Margin="0,6"
                               HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                <Entry Grid.Column="0"
                                       Text="{Binding Name, Mode=TwoWay}"
                                       Placeholder="Numele tău (sau pseudonimul de băutor)"
                                       PlaceholderColor="#99FFFFFF"
                                       TextColor="White"
                                       FontSize="18"
                                       BackgroundColor="Transparent"
                                       Margin="0,0,8,0"
                                       ClearButtonVisibility="WhileEditing"/>
                                <Button Grid.Column="1"
                                        Text="✕"
                                        Command="{Binding Source={x:Reference PlayerNamesPageRoot}, Path=BindingContext.RemovePlayerCommand}"
                                        CommandParameter="{Binding .}"
                                        WidthRequest="32"
                                        HeightRequest="32"
                                        CornerRadius="16"
                                        BackgroundColor="#44000000"
                                        TextColor="#FFF"
                                        FontSize="16"
                                        Padding="0"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Buttons -->
            <VerticalStackLayout Grid.Row="2" Spacing="12">
                <Button Text="+ Adaugă jucător"
                        Command="{Binding AddPlayerCommand}"
                        HeightRequest="50"
                        CornerRadius="25"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        BackgroundColor="Transparent"
                        BorderColor="#2ECC71"
                        BorderWidth="1.5"/>
                <Button Text="Începe jocul"
                        Command="{Binding StartGameCommand}"
                        HeightRequest="60"
                        CornerRadius="30"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="20"
                        Margin="0,8,0,0"
                        WidthRequest="240"
                        HorizontalOptions="Center">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2ECC71" Offset="0.0" />
                            <GradientStop Color="#27AE60" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </VerticalStackLayout>

        </Grid>
    </AbsoluteLayout>

</ContentPage>
